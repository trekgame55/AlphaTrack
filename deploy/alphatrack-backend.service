[Unit]
Description=AlphaTrack Backend (FastAPI + Uvicorn)
After=network.target

[Service]
Type=simple
User=alphatrack
WorkingDirectory=/opt/alphatrack/backend
ExecStart=/opt/alphatrack/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
